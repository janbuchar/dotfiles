#!/usr/bin/env bash
set -e # Exit immediately if a command exits with a non-zero status

# Colors for output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

echo -e "${BLUE}🔄 Git Worktree Converter${NC}"
echo "This script will convert the current standard repository into a 'Fake Normal Repo' worktree structure."

# 1. Validation
if [ ! -d ".git" ]; then
    echo -e "${RED}❌ Error: No .git directory found. Are you in the root of a repo?${NC}"
    exit 1
fi

if [ -f ".git" ]; then
    echo -e "${RED}❌ Error: This already looks like a worktree (found .git file, not directory).${NC}"
    exit 1
fi

if [[ -n $(git status --porcelain) ]]; then
    echo -e "${RED}❌ Error: Repository is dirty. Please commit or stash your changes first.${NC}"
    exit 1
fi

REPO_NAME=$(basename "$PWD")
CURRENT_BRANCH=$(git branch --show-current)
PARENT_DIR=$(dirname "$PWD")
ABS_PATH=$(pwd)

# 2. Preparation - Move things aside
echo -e "${BLUE}📦 Moving repository to temporary location...${NC}"

BACKUP_GIT="${PARENT_DIR}/${REPO_NAME}.git.backup"
BACKUP_FILES="${PARENT_DIR}/${REPO_NAME}.files.backup"

if [ -d "$BACKUP_GIT" ] || [ -d "$BACKUP_FILES" ]; then
    echo -e "${RED}❌ Error: Backup directories already exist ($BACKUP_GIT or $BACKUP_FILES). Please clean up manually.${NC}"
    exit 1
fi

# Move .git out first
mv .git "$BACKUP_GIT"

# Move everything else out
mkdir -p "$BACKUP_FILES"
shopt -s dotglob nullglob
files=(*)
if [ ${#files[@]} -gt 0 ]; then
    mv "${files[@]}" "$BACKUP_FILES/"
fi
shopt -u dotglob nullglob

# Directory is now empty (except for potentially . ..)

# 3. Create the Bare Structure
echo -e "${BLUE}🔧 Configuring bare repository...${NC}"

# Move git dir back, but as the hidden bare repo
mv "$BACKUP_GIT" .git

# Convert to bare
git --git-dir=.git config --bool core.bare true
# Ensure we fetch all branches correctly
git --git-dir=.git config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"

# IMPORTANT: Remove the index. Since we converted to bare, the index (staging area) 
# is meaningless and effectively blocks us from checking out the branch again.
rm -f .git/index

# 4. Create the Worktree
echo -e "${BLUE}🌱 Creating worktree for branch '${CURRENT_BRANCH}'...${NC}"

# We re-checkout the branch into a subdirectory
# Force is required because git thinks the branch is already checked out by the bare repo
if ! git --git-dir=.git worktree add -f "$CURRENT_BRANCH"; then
    echo -e "${RED}❌ Error: Failed to create worktree. Restoring backup...${NC}"
    # Minimal attempt to restore - manual intervention likely needed if this fails
    mv .git "$BACKUP_GIT"
    mv "$BACKUP_FILES"/* .
    mv "$BACKUP_GIT" .git
    rmdir "$BACKUP_FILES"
    exit 1
fi

# 5. Restore Files (Preserve Ignored Files)
echo -e "${BLUE}🚚 Restoring files (including ignored ones)...${NC}"

# The worktree add command gave us a fresh checkout.
# We want to overwrite it with the user's original files (to keep .env, node_modules, etc)
# We delete the fresh checkout files (except the new .git file)
find "$CURRENT_BRANCH" -mindepth 1 -not -name '.git' -delete

# Move original files into the worktree folder
shopt -s dotglob nullglob
mv "$BACKUP_FILES"/* "$CURRENT_BRANCH/"
shopt -u dotglob nullglob

# Cleanup empty backup dir
rmdir "$BACKUP_FILES"

# 6. Mise/Env Handling
echo -e "${BLUE}🔍 Checking for config files to promote to root...${NC}"

for file in mise.toml .mise.toml .nvim.lua; do
    if [ -f "$CURRENT_BRANCH/$file" ]; then
        echo -e "${GREEN}   Found $file! Moving to root...${NC}"
        mv "$CURRENT_BRANCH/$file" .
    fi
done

echo -e "${GREEN}✅ Conversion Complete!${NC}"
