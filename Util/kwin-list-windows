#!/usr/bin/env python3

import sys
import subprocess
import json
import argparse


def busctl_call(service, path, interface, method, signature=None, *args):
    """Call a D-Bus method via busctl and return parsed JSON data."""
    cmd = ['busctl', '--user', '--json=short', 'call', service, path, interface, method]
    if signature:
        cmd.append(signature)
        cmd.extend(args)
    result = subprocess.run(cmd, capture_output=True, text=True, timeout=2, check=True)
    return json.loads(result.stdout)['data']


def get_kwin_windows_in_activity(activity_id):
    """Get window info from KWin using busctl with JSON output"""
    try:
        # Use busctl to call the Match method - returns JSON
        match_data = busctl_call(
            "org.kde.KWin", "/WindowsRunner", "org.kde.krunner1", "Match", "s", ""
        )
        
        windows = []
        seen_uuids = set()
        
        # The data is an array of tuples: (id, caption, icon, priority, relevance, properties)
        for item in match_data[0]:
            window_id = item[0]  # Format: "0_{uuid}"
            
            # Skip non-window entries (e.g., desktop switchers that start with "8_")
            if not window_id.startswith('0_{'):
                continue
                
            # Deduplicate (UUIDs appear multiple times with different priorities)
            if window_id in seen_uuids:
                continue
            seen_uuids.add(window_id)
            
            # Extract UUID from format like "0_{uuid}"
            uuid = window_id.split('_{', 1)[1].rstrip('}')
            uuid = '{' + uuid + '}'
            
            # Get detailed window info including activities
            try:
                win_data = busctl_call(
                    "org.kde.KWin", "/KWin", "org.kde.KWin",
                    "getWindowInfo", "s", uuid
                )[0]  # data[0] is the a{sv} dict
                
                # Check if window is on current activity
                win_activities = win_data.get('activities', {}).get('data', [])
                # If activities is empty, window is on all activities
                if not win_activities or activity_id in win_activities:
                    windows.append({
                        "resourceName": win_data.get('resourceName', {}).get('data', ''),
                        "resourceClass": win_data.get('resourceClass', {}).get('data', ''),
                        "caption": win_data.get('caption', {}).get('data', '')
                    })
            except:
                pass
        
        return windows
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        return []

parser = argparse.ArgumentParser(
    description="List KWin windows in a specific activity"
)
parser.add_argument(
    "activity_id",
    nargs="?",
    help="Activity ID (defaults to current activity if not specified)"
)

if __name__ == "__main__":
    
    args = parser.parse_args()
    
    # Get current activity if not specified
    if args.activity_id:
        activity_id = args.activity_id
    else:
        activity_id = busctl_call(
            "org.kde.ActivityManager", "/ActivityManager/Activities",
            "org.kde.ActivityManager.Activities", "CurrentActivity"
        )[0]
    
    windows = get_kwin_windows_in_activity(activity_id)
    
    for win in windows:
        print(f"{win['resourceName']}\t{win['resourceClass']}\t{win['caption']}")
